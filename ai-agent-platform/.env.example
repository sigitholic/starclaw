# ============================================================
# Starclaw AI Agent Platform — Konfigurasi Environment
# Salin file ini ke .env dan isi sesuai kebutuhan
# ============================================================

# Node environment
NODE_ENV=development

# Port untuk API server (default: 8080)
PORT=8080

# Port untuk Dashboard Next.js (default: 3001)
DASHBOARD_PORT=3001

# ============================================================
# LLM Provider
# ============================================================
# Provider LLM: "openai" atau "mock" (mock = tanpa API key, untuk testing)
LLM_PROVIDER=openai

# Model OpenAI yang digunakan
LLM_MODEL=gpt-4o-mini

# API Key OpenAI (wajib jika LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# ============================================================
# Channel — Cara agent menerima perintah
# ============================================================
# Pilihan: "local" | "cli" | "telegram"
#   local    = agent berjalan standby tanpa input eksternal (default)
#   cli      = terima input dari command line argument
#   telegram = terima perintah via bot Telegram
AGENT_CHANNEL=local

# ============================================================
# Telegram Channel (wajib jika AGENT_CHANNEL=telegram)
# ============================================================
# Token bot dari @BotFather
TELEGRAM_BOT_TOKEN=

# Aktifkan pairing (true/false)
# Jika true, user harus /pair <code> sebelum bisa menggunakan bot
TELEGRAM_PAIRING_ENABLED=true

# Kode pairing yang harus dimasukkan user (buat kode yang kuat)
TELEGRAM_PAIRING_CODE=

# Path file JSON untuk menyimpan data pairing (opsional)
# Default: data/telegram-pairing.json
TELEGRAM_PAIRING_STORE_PATH=
